{
  "name": "spine-file-parser",
  "version": "0.1.0",
  "description": "Inspect Spine .spine project files and export them to typed JSON through the official Spine CLI.",
  "keywords": [
    "spine",
    "spine2d",
    "parser",
    "animation",
    "typescript"
  ],
  "homepage": "https://github.com/neko233-com/spine-file-parser#readme",
  "bugs": {
    "url": "https://github.com/neko233-com/spine-file-parser/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/neko233-com/spine-file-parser.git"
  },
  "license": "MIT",
  "author": "neko233-com",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "import": "./dist/node.js"
    }
  },
  "scripts": {
    "build": "vite build",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run check && npm test && npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "fflate": "^0.8.2"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.9.0",
    "vite": "^8.1.5",
    "vite-plugin-dts": "^5.0.3",
    "vitest": "^4.1.10"
  }
}
